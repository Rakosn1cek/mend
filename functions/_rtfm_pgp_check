# functions/_rtfm_pgp_check
_rtfm_pgp_check() {
    local last_cmd="$1"
    # Scrape history for the specific PGP error string
    local pgp_key=$(fc -ln -20 | grep -iE "unknown public key|could not be verified" | grep -oE '[A-F0-9]{16,40}' | tail -1)

    if [[ -n "$pgp_key" ]]; then
        print -P "%F{yellow}RTFM:%f Detected missing PGP key: %F{cyan}$pgp_key%f"
        if read -q "choice?Import this key from keyserver? (y/n) "; then
            echo ""
            gpg --keyserver keyserver.ubuntu.com --recv-keys "$pgp_key"
            print -z "$last_cmd"
            return 0
        fi
    fi
    return 1
}
